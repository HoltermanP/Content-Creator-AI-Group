"use client";

import { useSession, signOut } from "next-auth/react";
import { useRouter } from "next/navigation";
import { useEffect, useState } from "react";
import { motion } from "framer-motion";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import {
  Sparkles,
  Plus,
  Calendar,
  BarChart3,
  MessageSquare,
  Building,
  TrendingUp,
  Clock,
  CheckCircle,
  AlertCircle,
  ArrowRight,
  Settings,
  Play,
  Target,
  Users,
  Zap,
  Star
} from "lucide-react";
import Link from "next/link";
import WorkflowHeader from "@/components/WorkflowHeader";

interface DashboardStats {
  totalPosts: number;
  publishedPosts: number;
  scheduledPosts: number;
  draftPosts: number;
  totalCompanies: number;
  creditsUsed: number;
  creditsRemaining: number;
}

interface RecentPost {
  id: string;
  title: string;
  status: string;
  scheduledAt?: string;
  publishedAt?: string;
  company: {
    name: string;
  };
}

interface OnboardingStep {
  id: string;
  title: string;
  description: string;
  completed: boolean;
  action: string;
  href: string;
  icon: React.ComponentType<any>;
}

export default function Dashboard() {
  const { data: session, status } = useSession();
  const router = useRouter();
  const [stats, setStats] = useState<DashboardStats>({
    totalPosts: 0,
    publishedPosts: 0,
    scheduledPosts: 0,
    draftPosts: 0,
    totalCompanies: 0,
    creditsUsed: 0,
    creditsRemaining: 50
  });
  const [recentPosts, setRecentPosts] = useState<RecentPost[]>([]);
  const [isNewUser, setIsNewUser] = useState(false);
  const [onboardingSteps, setOnboardingSteps] = useState<OnboardingStep[]>([]);

  const updateOnboardingProgress = (stepId: string, completed: boolean) => {
    setOnboardingSteps(prev =>
      prev.map(step =>
        step.id === stepId ? { ...step, completed } : step
      )
    );
  };

  useEffect(() => {
    if (status === "loading") return;

    if (!session) {
      router.push("/auth/signin");
      return;
    }

    // TODO: Fetch actual dashboard data from API
    // For now, simulate checking if user is new
    const checkIfNewUser = async () => {
      // Simulate API call to check if user has companies/posts
      // In real implementation, check from database
      const hasCompanies = false; // await checkUserHasCompanies()
      const hasPosts = false; // await checkUserHasPosts()
      const hasScheduledPosts = false; // await checkUserHasScheduledPosts()
      const hasAnalytics = false; // await checkUserHasAnalytics()

      const hasData = hasCompanies || hasPosts;

      if (hasData) {
        // Existing user with data - show normal dashboard
        setIsNewUser(false);
        setStats({
          totalPosts: 12,
          publishedPosts: 8,
          scheduledPosts: 3,
          draftPosts: 1,
          totalCompanies: 2,
          creditsUsed: 23,
          creditsRemaining: 27
        });

        setRecentPosts([
          {
            id: "1",
            title: "Nieuwe AI-feature gelanceerd",
            status: "PUBLISHED",
            publishedAt: "2024-01-15T10:30:00Z",
            company: { name: "TechCorp Netherlands" }
          },
          {
            id: "2",
            title: "Q4 resultaten bekend gemaakt",
            status: "SCHEDULED",
            scheduledAt: "2024-01-20T09:00:00Z",
            company: { name: "TechCorp Netherlands" }
          },
          {
            id: "3",
            title: "Team uitbreiding aangekondigd",
            status: "DRAFT",
            company: { name: "De Vries Consultancy" }
          }
        ]);
      } else {
        // New user - show onboarding flow
        setIsNewUser(true);
        setOnboardingSteps([
          {
            id: "company",
            title: "Stel je bedrijf in",
            description: "Voeg je eerste bedrijf toe zodat GenPostAI weet waarover je schrijft",
            completed: hasCompanies,
            action: "Bedrijf toevoegen",
            href: "/dashboard/companies",
            icon: Building
          },
          {
            id: "post",
            title: "Maak je eerste post",
            description: "Genereer professionele LinkedIn content met AI hulp",
            completed: hasPosts,
            action: "Post maken",
            href: "/dashboard/posts/new",
            icon: MessageSquare
          },
          {
            id: "schedule",
            title: "Plan je content",
            description: "Stel een content kalender op voor consistente posting",
            completed: hasScheduledPosts,
            action: "Kalender bekijken",
            href: "/dashboard/calendar",
            icon: Calendar
          },
          {
            id: "analytics",
            title: "Optimaliseer & analyseer",
            description: "Bekijk analytics en optimaliseer je content strategie",
            completed: hasAnalytics,
            action: "Analytics bekijken",
            href: "/dashboard/analytics",
            icon: BarChart3
          }
        ]);
      }
    };

    checkIfNewUser();
  }, [session, status, router]);

  if (status === "loading") {
    return (
      <div className="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100 flex items-center justify-center">
        <div className="text-center">
          <Sparkles className="h-12 w-12 text-blue-600 animate-pulse mx-auto mb-4" />
          <p className="text-gray-600">Dashboard laden...</p>
        </div>
      </div>
    );
  }

  const getStatusIcon = (status: string) => {
    switch (status) {
      case "PUBLISHED":
        return <CheckCircle className="h-4 w-4 text-green-500" />;
      case "SCHEDULED":
        return <Clock className="h-4 w-4 text-blue-500" />;
      case "DRAFT":
        return <AlertCircle className="h-4 w-4 text-yellow-500" />;
      default:
        return <AlertCircle className="h-4 w-4 text-gray-500" />;
    }
  };

  const getStatusText = (status: string) => {
    switch (status) {
      case "PUBLISHED":
        return "Gepubliceerd";
      case "SCHEDULED":
        return "Gepland";
      case "DRAFT":
        return "Concept";
      default:
        return "Onbekend";
    }
  };

  // Onboarding UI for new users
  if (isNewUser) {
    const completedSteps = onboardingSteps.filter(step => step.completed).length;
    const progress = (completedSteps / onboardingSteps.length) * 100;

    return (
      <div className="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100 relative overflow-hidden">
        {/* Background decorations for onboarding */}
        <div className="absolute inset-0 opacity-3">
          <div className="absolute top-20 left-20 w-64 h-64 bg-gradient-to-br from-blue-400/10 to-cyan-400/10 rounded-full blur-3xl animate-float"></div>
          <div className="absolute bottom-20 right-20 w-80 h-80 bg-gradient-to-br from-purple-400/8 to-pink-400/8 rounded-full blur-3xl animate-float animation-delay-1000"></div>
          <div className="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-gradient-to-br from-indigo-400/6 to-blue-400/6 rounded-full blur-3xl animate-float animation-delay-2000"></div>
        </div>

        {/* Floating particles */}
        <div className="absolute inset-0">
          {Array.from({ length: 15 }).map((_, i) => (
            <div
              key={i}
              className="absolute w-1 h-1 bg-blue-400/30 rounded-full animate-float"
              style={{
                left: `${Math.random() * 100}%`,
                top: `${Math.random() * 100}%`,
                animationDelay: `${Math.random() * 3000}ms`,
                animationDuration: `${2000 + Math.random() * 2000}ms`
              }}
            />
          ))}
        </div>

        <WorkflowHeader />

        <div className="container mx-auto px-4 py-12 relative z-10">
          {/* Hero Section */}
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, ease: "easeOut" }}
            className="text-center mb-12"
          >
            <div className="mb-6">
              <Sparkles className="h-16 w-16 text-blue-600 mx-auto mb-4" />
              <h1 className="text-4xl font-bold text-gray-900 mb-4">
                Welkom bij GenPostAI, {session?.user?.name?.split(' ')[0] || "Gebruiker"}! 🎉
              </h1>
              <p className="text-xl text-gray-600 max-w-2xl mx-auto">
                Je bent er klaar voor om je LinkedIn presence naar een hoger niveau te tillen.
                Laten we beginnen met het instellen van je account.
              </p>
            </div>

            {/* Quick Stats */}
            <motion.div
              initial={{ opacity: 0, y: 30 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ duration: 0.8, delay: 0.2 }}
              className="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-3xl mx-auto mb-8"
            >
              <motion.div
                initial={{ opacity: 0, scale: 0.8 }}
                animate={{ opacity: 1, scale: 1 }}
                transition={{ duration: 0.6, delay: 0.3 }}
              >
                <Card className="border-blue-200 bg-blue-50/50 hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
                  <CardContent className="pt-6 text-center">
                    <Target className="h-8 w-8 text-blue-600 mx-auto mb-2" />
                    <div className="text-2xl font-bold text-blue-900">0</div>
                    <p className="text-sm text-blue-700">Bedrijven</p>
                  </CardContent>
                </Card>
              </motion.div>
              <motion.div
                initial={{ opacity: 0, scale: 0.8 }}
                animate={{ opacity: 1, scale: 1 }}
                transition={{ duration: 0.6, delay: 0.4 }}
              >
                <Card className="border-green-200 bg-green-50/50 hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
                  <CardContent className="pt-6 text-center">
                    <MessageSquare className="h-8 w-8 text-green-600 mx-auto mb-2" />
                    <div className="text-2xl font-bold text-green-900">0</div>
                    <p className="text-sm text-green-700">Posts</p>
                  </CardContent>
                </Card>
              </motion.div>
              <motion.div
                initial={{ opacity: 0, scale: 0.8 }}
                animate={{ opacity: 1, scale: 1 }}
                transition={{ duration: 0.6, delay: 0.5 }}
              >
                <Card className="border-purple-200 bg-purple-50/50 hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
                  <CardContent className="pt-6 text-center">
                    <Zap className="h-8 w-8 text-purple-600 mx-auto mb-2" />
                    <div className="text-2xl font-bold text-purple-900">50</div>
                    <p className="text-sm text-purple-700">Credits</p>
                  </CardContent>
                </Card>
              </motion.div>
          </motion.div>

          {/* Onboarding Steps */}
          <motion.div
            initial={{ opacity: 0, y: 30 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 0.6 }}
            className="max-w-4xl mx-auto"
          >
            <h2 className="text-2xl font-bold text-center mb-8 text-gray-900">
              Laten we je account instellen in 4 stappen
            </h2>

            <div className="space-y-6">
              {onboardingSteps.map((step, index) => {
                const Icon = step.icon;
                return (
                  <motion.div
                    key={step.id}
                    initial={{ opacity: 0, x: -20 }}
                    animate={{ opacity: 1, x: 0 }}
                    transition={{ delay: index * 0.1 }}
                  >
                    <Card className={`transition-all duration-300 hover:shadow-lg ${
                      step.completed ? 'border-green-200 bg-green-50/30' : 'border-gray-200'
                    }`}>
                      <CardContent className="pt-6">
                        <div className="flex items-start gap-4">
                          <div className={`p-3 rounded-full ${
                            step.completed ? 'bg-green-100' : 'bg-gray-100'
                          }`}>
                            <Icon className={`h-6 w-6 ${
                              step.completed ? 'text-green-600' : 'text-gray-600'
                            }`} />
                          </div>

                          <div className="flex-1">
                            <div className="flex items-center gap-3 mb-2">
                              <h3 className="text-lg font-semibold text-gray-900">
                                {step.title}
                              </h3>
                              {step.completed && (
                                <Badge className="bg-green-100 text-green-800">
                                  <CheckCircle className="h-3 w-3 mr-1" />
                                  Voltooid
                                </Badge>
                              )}
                            </div>

                            <p className="text-gray-600 mb-4">
                              {step.description}
                            </p>

                            <div className="flex items-center justify-between">
                              <div className="text-sm text-gray-500">
                                Stap {index + 1} van {onboardingSteps.length}
                              </div>
                              <Link href={step.href}>
                                <Button
                                  className={step.completed ? 'bg-green-600 hover:bg-green-700' : ''}
                                  disabled={index > 0 && !onboardingSteps[index - 1].completed}
                                >
                                  {step.action}
                                  <ArrowRight className="ml-2 h-4 w-4" />
                                </Button>
                              </Link>
                            </div>
                          </div>
                        </div>
                      </CardContent>
                    </Card>
                  </motion.div>
                );
              })}
            </div>

            {/* Skip option for advanced users */}
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              transition={{ duration: 0.8, delay: 1.2 }}
              className="text-center mt-8"
            >
              <p className="text-sm text-gray-600 mb-4">
                Al bekend met GenPostAI? Je kunt deze setup ook overslaan.
              </p>
              <Button variant="outline" onClick={() => setIsNewUser(false)}>
                <Play className="mr-2 h-4 w-4" />
                Direct beginnen
              </Button>
            </motion.div>
          </motion.div>
        </div>
      </div>
    );
  }

  // Regular dashboard for existing users
  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100 relative overflow-hidden">
      {/* Background decorations for dashboard */}
      <div className="absolute inset-0 opacity-3">
        <div className="absolute top-20 left-20 w-64 h-64 bg-gradient-to-br from-blue-400/10 to-cyan-400/10 rounded-full blur-3xl animate-float"></div>
        <div className="absolute bottom-20 right-20 w-80 h-80 bg-gradient-to-br from-purple-400/8 to-pink-400/8 rounded-full blur-3xl animate-float animation-delay-1000"></div>
        <div className="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-gradient-to-br from-indigo-400/6 to-blue-400/6 rounded-full blur-3xl animate-float animation-delay-2000"></div>
      </div>

      {/* Floating particles */}
      <div className="absolute inset-0">
        {Array.from({ length: 15 }).map((_, i) => (
          <div
            key={i}
            className="absolute w-1 h-1 bg-blue-400/30 rounded-full animate-float"
            style={{
              left: `${Math.random() * 100}%`,
              top: `${Math.random() * 100}%`,
              animationDelay: `${Math.random() * 3000}ms`,
              animationDuration: `${2000 + Math.random() * 2000}ms`
            }}
          />
        ))}
      </div>

      <WorkflowHeader />

      <div className="container mx-auto px-4 py-8 relative z-10">
        {/* Welcome Section */}
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.8, ease: "easeOut" }}
          className="mb-8"
        >
          <h1 className="text-3xl font-bold text-gray-900 mb-2">
            Welkom terug, {session?.user?.name || "Gebruiker"}! 👋
          </h1>
          <p className="text-gray-600">
            Hier is een overzicht van je LinkedIn content activiteit
          </p>
        </motion.div>

        {/* Stats Grid */}
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.1, duration: 0.8 }}
          className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8"
        >
          <Card className="bg-white/80 backdrop-blur-sm border-0 shadow-lg hover:shadow-xl transition-all duration-500 hover:-translate-y-2 overflow-hidden group">
            <div className="bg-gradient-to-r from-blue-500 to-cyan-500 p-4 text-white">
              <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
                <CardTitle className="text-sm font-medium text-white">Totaal Posts</CardTitle>
                <MessageSquare className="h-5 w-5 text-white/90" />
              </CardHeader>
            </div>
            <CardContent className="p-6">
              <div className="text-2xl font-bold text-gray-900">{stats.totalPosts}</div>
              <p className="text-xs text-gray-600 mt-1">
                +2 sinds vorige maand
              </p>
            </CardContent>
          </Card>

          <Card className="bg-white/80 backdrop-blur-sm border-0 shadow-lg hover:shadow-xl transition-all duration-500 hover:-translate-y-2 overflow-hidden group">
            <div className="bg-gradient-to-r from-green-500 to-emerald-500 p-4 text-white">
              <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
                <CardTitle className="text-sm font-medium text-white">Gepubliceerd</CardTitle>
                <CheckCircle className="h-5 w-5 text-white/90" />
              </CardHeader>
            </div>
            <CardContent className="p-6">
              <div className="text-2xl font-bold text-gray-900">{stats.publishedPosts}</div>
              <p className="text-xs text-gray-600 mt-1">
                {Math.round((stats.publishedPosts / stats.totalPosts) * 100)}% van totaal
              </p>
            </CardContent>
          </Card>

          <Card className="bg-white/80 backdrop-blur-sm border-0 shadow-lg hover:shadow-xl transition-all duration-500 hover:-translate-y-2 overflow-hidden group">
            <div className="bg-gradient-to-r from-purple-500 to-pink-500 p-4 text-white">
              <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
                <CardTitle className="text-sm font-medium text-white">Gepland</CardTitle>
                <Calendar className="h-5 w-5 text-white/90" />
              </CardHeader>
            </div>
            <CardContent className="p-6">
              <div className="text-2xl font-bold text-gray-900">{stats.scheduledPosts}</div>
              <p className="text-xs text-gray-600 mt-1">
                Voor komende periode
              </p>
            </CardContent>
          </Card>

          <Card className="bg-white/80 backdrop-blur-sm border-0 shadow-lg hover:shadow-xl transition-all duration-500 hover:-translate-y-2 overflow-hidden group">
            <div className="bg-gradient-to-r from-indigo-500 to-purple-500 p-4 text-white">
              <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
                <CardTitle className="text-sm font-medium text-white">Credits</CardTitle>
                <TrendingUp className="h-5 w-5 text-white/90" />
              </CardHeader>
            </div>
            <CardContent className="p-6">
              <div className="text-2xl font-bold text-gray-900">{stats.creditsRemaining}</div>
              <p className="text-xs text-gray-600 mt-1">
                Nog {stats.creditsRemaining} beschikbaar
              </p>
            </CardContent>
          </Card>
        </motion.div>

        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.3, duration: 0.8 }}
          className="grid grid-cols-1 lg:grid-cols-3 gap-8"
        >
          {/* Recent Posts */}
          <motion.div
            initial={{ opacity: 0, x: -20 }}
            animate={{ opacity: 1, x: 0 }}
            transition={{ delay: 0.4, duration: 0.6 }}
            className="lg:col-span-2"
          >
            <Card className="bg-white/80 backdrop-blur-sm border-0 shadow-xl hover:shadow-2xl transition-all duration-500 overflow-hidden">
              <div className="bg-gradient-to-r from-slate-600 to-slate-700 p-6 text-white">
                <CardHeader className="p-0">
                  <div className="flex items-center justify-between">
                    <CardTitle className="text-white">Recente Posts</CardTitle>
                    <Link href="/dashboard/posts">
                      <Button variant="outline" size="sm" className="border-white/20 bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white">
                        Alle posts bekijken
                      </Button>
                    </Link>
                  </div>
                  <CardDescription className="text-slate-200 mt-2">
                    Je meest recente LinkedIn posts en hun status
                  </CardDescription>
                </CardHeader>
              </div>
              <CardContent>
                <div className="space-y-4">
                  {recentPosts.map((post) => (
                    <div key={post.id} className="flex items-center justify-between p-4 border rounded-lg">
                      <div className="flex items-center space-x-4">
                        {getStatusIcon(post.status)}
                        <div>
                          <h4 className="font-medium">{post.title}</h4>
                          <p className="text-sm text-gray-600">{post.company.name}</p>
                        </div>
                      </div>
                      <Badge variant={
                        post.status === "PUBLISHED" ? "default" :
                        post.status === "SCHEDULED" ? "secondary" : "outline"
                      }>
                        {getStatusText(post.status)}
                      </Badge>
                    </div>
                  ))}
                </div>
              </CardContent>
            </Card>
          </motion.div>

          {/* Quick Actions */}
          <motion.div
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            transition={{ delay: 0.5, duration: 0.6 }}
            className="space-y-6"
          >
            <Card className="bg-white/80 backdrop-blur-sm border-0 shadow-xl hover:shadow-2xl transition-all duration-500 overflow-hidden">
              <div className="bg-gradient-to-r from-blue-600 to-purple-600 p-6 text-white">
                <CardHeader className="p-0">
                  <CardTitle className="text-white">Snel aan de slag</CardTitle>
                  <CardDescription className="text-blue-100 mt-2">
                    Start met het maken van nieuwe content
                  </CardDescription>
                </CardHeader>
              </div>
              <CardContent className="space-y-3">
                <Link href="/dashboard/posts/new">
                  <Button className="w-full" size="sm">
                    <Plus className="mr-2 h-4 w-4" />
                    Nieuwe post maken
                  </Button>
                </Link>
                <Link href="/dashboard/calendar">
                  <Button variant="outline" className="w-full" size="sm">
                    <Calendar className="mr-2 h-4 w-4" />
                    Content kalender bekijken
                  </Button>
                </Link>
                <Link href="/dashboard/companies">
                  <Button variant="outline" className="w-full" size="sm">
                    <Building className="mr-2 h-4 w-4" />
                    Bedrijven beheren
                  </Button>
                </Link>
                <Link href="/dashboard/analytics">
                  <Button variant="outline" className="w-full" size="sm">
                    <BarChart3 className="mr-2 h-4 w-4" />
                    Analytics bekijken
                  </Button>
                </Link>
              </CardContent>
            </Card>

            <Card className="bg-white/80 backdrop-blur-sm border-0 shadow-xl hover:shadow-2xl transition-all duration-500 overflow-hidden">
              <div className="bg-gradient-to-r from-green-600 to-emerald-600 p-6 text-white">
                <CardHeader className="p-0">
                  <CardTitle className="text-white">Bedrijven</CardTitle>
                  <CardDescription className="text-green-100 mt-2">
                    Je geconfigureerde bedrijven
                  </CardDescription>
                </CardHeader>
              </div>
              <CardContent>
                <div className="space-y-3">
                  <div className="flex items-center justify-between p-3 bg-blue-50 rounded-lg">
                    <div className="flex items-center space-x-3">
                      <Building className="h-5 w-5 text-blue-600" />
                      <div>
                        <p className="font-medium">TechCorp Netherlands</p>
                        <p className="text-sm text-gray-600">SaaS Analytics</p>
                      </div>
                    </div>
                    <Badge variant="secondary">Premium</Badge>
                  </div>
                  <div className="flex items-center justify-between p-3 bg-green-50 rounded-lg">
                    <div className="flex items-center space-x-3">
                      <Building className="h-5 w-5 text-green-600" />
                      <div>
                        <p className="font-medium">De Vries Consultancy</p>
                        <p className="text-sm text-gray-600">Management Consulting</p>
                      </div>
                    </div>
                    <Badge variant="secondary">Premium</Badge>
                  </div>
                </div>
              </CardContent>
            </Card>
          </motion.div>
        </motion.div>
      </div>
    </div>
  );
}